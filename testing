local function findPlayerByName(partial)
	partial=partial:lower()
	for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer and p.Name:lower():sub(1,#partial)==partial then return p end end
end
_reg(LocalPlayer.Chatted:Connect(function(msg)
	local a=msg:lower():split(" ")
	if a[1]=="!fly" and not SCRIPT_CLOSED then
		if a[2] then local n=tonumber(a[2]); if n then flySpeed=math.clamp(n,5,500); SpeedBox.Text=tostring(flySpeed) end end
		startFly(); FlyBtn.Text="[S] Stop Flying"; FlyBtn.BackgroundColor3=C.ACCENT2
	end
	if a[1]=="!unfly" then stopFly(); FlyBtn.Text="[^] Start Flying"; FlyBtn.BackgroundColor3=C.BG3 end
	if a[1]=="!loop" and a[2] then loopTarget=findPlayerByName(a[2]); looping=true end
	if a[1]=="!unloop" then looping=false end
	if a[1]=="!orbit" and a[2] then orbitTarget=findPlayerByName(a[2]); orbiting=true end
	if a[1]=="!unorbit" then orbiting=false end
	if a[1]=="!antifling" then antiFlingEnabled=true; startAntiFling(); AntiFlingBtn.Text="[AF] Anti-Fling: ON"; AntiFlingBtn.BackgroundColor3=C.SUCCESS end
	if a[1]=="!unantifling" then antiFlingEnabled=false; stopAntiFling(); AntiFlingBtn.Text="[AF] Anti-Fling: OFF"; AntiFlingBtn.BackgroundColor3=C.BG3 end
	if a[1]=="!esp" then espEnabled=true; clearESP(); for _,p in ipairs(Players:GetPlayers()) do applyHighlight(p) end; EspBtn.Text="[E] ESP: ON"; EspBtn.BackgroundColor3=C.ACCENT2 end
	if a[1]=="!unesp" then espEnabled=false; clearESP(); EspBtn.Text="[E] ESP: OFF"; EspBtn.BackgroundColor3=C.BG3 end
	if a[1]=="!rejoin" then TeleportService:Teleport(game.PlaceId,LocalPlayer) end
	if a[1]=="!refresh" and LocalPlayer.Character then LocalPlayer.Character:BreakJoints() end
	if a[1]=="!invis" then
		if not invisEnabled then
			startInvis()

			if InvisBtn then
				InvisBtn.Text="[I] Invis (G): ON"
				InvisBtn.BackgroundColor3=C.SUCCESS
			end
		end
	end

	if a[1]=="!uninvis" then
		if invisEnabled then
			stopInvis()

			if InvisBtn then
				InvisBtn.Text="[I] Invis (G): OFF"
				InvisBtn.BackgroundColor3=C.BG3
			end
		end
	end
	if a[1]=="!float" then
		if not FloatEnabled then StartFloat(); FloatBtn.Text="[~] Float: ON"; FloatBtn.BackgroundColor3=C.ACCENT2 end
	end
	if a[1]=="!unfloat" then
		if FloatEnabled then StopFloat(); FloatBtn.Text="[~] Float: OFF"; FloatBtn.BackgroundColor3=C.BG3 end
	end
end))
