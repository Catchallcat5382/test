-- =========================================================
-- INVISIBILITY SYSTEM (FULLY CLEANABLE)
-- =========================================================

local invisEnabled = false
local invisSaved = {}
local InvisBtn
local invisConn

local INVIS_ON = Color3.fromRGB(85,255,127)

local function restoreTransparency()

	for v,t in pairs(invisSaved) do
		if v and v.Parent then
			if v:IsA("BasePart") then
				v.LocalTransparencyModifier = t
			elseif v:IsA("Decal") then
				v.Transparency = t
			end
		end
	end

	table.clear(invisSaved)

end


local function startInvis()

	if invisEnabled then return end

	local char = LocalPlayer.Character
	if not char then return end

	invisEnabled = true
	table.clear(invisSaved)

	for _,v in ipairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			invisSaved[v] = v.LocalTransparencyModifier
			v.LocalTransparencyModifier = 0.5

		elseif v:IsA("Decal") then
			invisSaved[v] = v.Transparency
			v.Transparency = 0.5
		end
	end

	local invisKeyConn
	local invisConn

	invisConn = _reg(RunService.Heartbeat:Connect(function()

		if not invisEnabled then return end

		local char = LocalPlayer.Character
		if not char then return end

		local humanoid = char:FindFirstChildOfClass("Humanoid")
		local root = char:FindFirstChild("HumanoidRootPart")

		if not humanoid or not root then return end

		local current = root.CFrame
		local offset = humanoid.CameraOffset

		local new = current * CFrame.new(0,-2000,0)

		local camOffset =
			new:ToObjectSpace(
				CFrame.new(current.Position)
			).Position

		root.CFrame = new
		humanoid.CameraOffset = camOffset

		RunService.RenderStepped:Wait()

		root.CFrame = current
		humanoid.CameraOffset = offset

	end))

end


local function stopInvis()

	if not invisEnabled then return end

	invisEnabled = false

	if invisConn then
