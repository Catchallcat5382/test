-- ── QUEUE + CHAT HANDLER ─────────────────────────────────
local ai_playerLastSent={}; local ai_messageQueue={}; local ai_queueRunning=false
local ai_groqPaused=false; local ai_groqRetryAt=0

local function ai_sendRobloxChat(targetUsername,reply)
	if not ai_canSendRobloxChat() then
		task.spawn(function() while not ai_canSendRobloxChat() do task.wait(1) end; ai_sendRobloxChat(targetUsername,reply) end); return
	end
	local r=reply; if #r>0 then r=r:sub(1,1):lower()..r:sub(2) end
	local msg="[AI]: "..targetUsername..", "..r; if #msg>200 then msg=msg:sub(1,197).."..." end
	task.spawn(function()
		local ok=pcall(function()
			local tcs=game:GetService("TextChatService"); local ch=tcs.TextChannels:FindFirstChild("RBXGeneral")
			if ch then ch:SendAsync(msg); ai_recordSend() end
		end)
		if not ok then
			task.wait(3)
			pcall(function()
				local tcs=game:GetService("TextChatService"); local ch=tcs.TextChannels:FindFirstChild("RBXGeneral")
				if ch then ch:SendAsync(msg); ai_recordSend() end
			end)
		end
	end)
end

local function ai_processQueue()
	if ai_queueRunning then return end; ai_queueRunning=true
	task.spawn(function()
		while #ai_messageQueue>0 do
			while ai_groqPaused do task.wait(1) end
			local item=table.remove(ai_messageQueue,1); local player=item.player; local message=item.message; local uid=player.UserId
			if ai_playerLastSent[uid] then local w=AI_COOLDOWN-(tick()-ai_playerLastSent[uid]); if w>0 then task.wait(w) end end
			ai_addLog(player.Name,message,"user")
			if aiFooter.Parent then aiFooter.Text=player.Name..": "..message:sub(1,40) end
			local reply,err=ai_callGroq(item.apiKey,item.sysPrompt,uid,player.Name,message)
			ai_playerLastSent[uid]=tick()
			if reply then
				if ai_hasBad(reply) then reply = AI_BLOCKED end
				ai_addLog("Groq",reply,"ai")
				if aiFooter.Parent then aiFooter.Text="Replied to "..player.Name.."." end
				if ai_getSendChat() then ai_sendRobloxChat(player.Name,reply) end
			elseif err=="RATE_LIMITED" then
				ai_addLog("","Rate limited. Pausing 60s.","sys"); ai_groqPaused=true; ai_groqRetryAt=tick()+60
				table.insert(ai_messageQueue,1,item)
				task.spawn(function()
					while ai_groqPaused do local r2=math.ceil(ai_groqRetryAt-tick()); if r2<=0 then break end
						if aiFooter.Parent then aiFooter.Text="Rate limited. Resuming in "..r2.."s." end; task.wait(1)
					end; ai_groqPaused=false; if aiFooter.Parent then aiFooter.Text="Resumed." end
				end)
			elseif err=="BAD_KEY" then
				ai_addLog("","Invalid API key.","sys"); if aiFooter.Parent then aiFooter.Text="Bad API key." end; break
			else ai_addLog("","Error: "..tostring(err),"sys") end
			task.wait(0.5)
		end
		ai_queueRunning=false; if aiFooter.Parent then aiFooter.Text="Waiting for messages." end
	end)
end

local function ai_handleChat(player,message)
	if not ai_getAutoRespond() then return end
	if player==LocalPlayer and not ai_getRespondSelf() then return end
	local apiKey=aiKeyBox.Text
	if apiKey=="" then ai_addLog("","No API key set.","sys"); return end
	if not ai_getRespondAll() then
		local trigger=aiTrigBox.Text:lower():gsub("%s+","")
		if trigger~="" and not message:lower():find(trigger,1,true) then return end
	end
	if ai_block(message) then
		ai_addLog(player.Name,message,"user"); ai_addLog("Groq",AI_BLOCKED,"ai")
		if ai_getSendChat() then ai_sendRobloxChat(player.Name,AI_BLOCKED) end; return
	end
	table.insert(ai_messageQueue,{player=player,message=message,apiKey=apiKey,sysPrompt=aiSysBox.Text,userId=player.UserId})
	ai_processQueue()
end

local function ai_hookPlayer(p) _reg(p.Chatted:Connect(function(msg) ai_handleChat(p,msg) end)) end
for _,p in ipairs(Players:GetPlayers()) do ai_hookPlayer(p) end
_reg(Players.PlayerAdded:Connect(ai_hookPlayer))

