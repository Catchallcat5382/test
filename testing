local loopTarget,looping=nil,false; local orbitTarget,orbiting=nil,false
local orbitAngle,orbitRadius,orbitSpeed=0,6,2

local function instantGoto(player)
	local char=LocalPlayer.Character; local targetChar=player and player.Character
	if not(char and targetChar) then return end
	local myHRP=char:FindFirstChild("HumanoidRootPart"); local targetHRP=targetChar:FindFirstChild("HumanoidRootPart")
	if not(myHRP and targetHRP) then return end
	myHRP.CFrame=CFrame.new(targetHRP.Position-targetHRP.CFrame.LookVector*2+Vector3.new(0,0.1,0),targetHRP.Position)
	myHRP.AssemblyLinearVelocity=Vector3.zero
end
local function softFollow(player)
	local char=LocalPlayer.Character; local targetChar=player and player.Character
	if not(char and targetChar) then return end
	local myHRP=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
	local tarHRP=targetChar:FindFirstChild("HumanoidRootPart")
	if not(myHRP and hum and tarHRP) then return end
	if hum.Sit then hum.Sit=false end
	local desiredPos=tarHRP.Position-tarHRP.CFrame.LookVector*2+Vector3.new(0,0.1,0)
	local delta=desiredPos-myHRP.Position; local dist=delta.Magnitude
	if dist>12 then myHRP.CFrame=CFrame.new(desiredPos,tarHRP.Position); myHRP.AssemblyLinearVelocity=Vector3.zero; return end
	myHRP.AssemblyLinearVelocity=delta.Unit*math.min(dist*12,40)
end
_reg(RunService.Heartbeat:Connect(function(dt)
	if looping and loopTarget then softFollow(loopTarget) end
	if orbiting and orbitTarget and orbitTarget.Character then
		local hrp=orbitTarget.Character:FindFirstChild("HumanoidRootPart")
		local my=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if hrp and my then
			orbitAngle+=dt*orbitSpeed
			my.CFrame=CFrame.new(hrp.Position+Vector3.new(math.cos(orbitAngle)*orbitRadius,2,math.sin(orbitAngle)*orbitRadius),hrp.Position)
		end
	end
end))

