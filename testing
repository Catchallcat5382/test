local function httpPost(url,headers,body)
	local fn=(syn and syn.request) or (http and http.request)
		or (typeof(request)=="function" and request) or (typeof(http_request)=="function" and http_request)
		or (fluxus and fluxus.request)
	if not fn then return nil,"No HTTP function found" end
	local ok,resp=pcall(fn,{Url=url,Method="POST",Headers=headers,Body=body})
	if not ok then return nil,tostring(resp) end; return resp,nil
end

local ai_history={}
local function ai_getHistory(uid) if not ai_history[uid] then ai_history[uid]={} end; return ai_history[uid] end
local function ai_addToHistory(uid,role,content)
	local h=ai_getHistory(uid); table.insert(h,{role=role,content=content})
	while #h>MAX_HISTORY do table.remove(h,1) end
end
local function ai_callGroq(apiKey,systemPrompt,userId,senderName,userMessage)
	if not apiKey or apiKey=="" then return nil,"NO_KEY" end
	ai_addToHistory(userId,"user",senderName.." says: "..userMessage)
	local messages={{role="system",content=systemPrompt..GRAMMAR_SUFFIX}}
	for _,e in ipairs(ai_getHistory(userId)) do table.insert(messages,e) end
	local ok,body=pcall(HttpService.JSONEncode,HttpService,{model=ai_selectedModel,max_tokens=150,messages=messages})
	if not ok then return nil,"JSON_ENCODE" end
	local resp,err=httpPost(GROQ_URL,{["Content-Type"]="application/json",["Authorization"]="Bearer "..apiKey},body)
	if not resp then local h=ai_getHistory(userId); if #h>0 then table.remove(h,#h) end; return nil,err end
	if resp.StatusCode==429 then return nil,"RATE_LIMITED" end
	if resp.StatusCode==401 then return nil,"BAD_KEY" end
	if resp.StatusCode~=200 then
		local h=ai_getHistory(userId); if #h>0 then table.remove(h,#h) end
		local msg="HTTP_"..tostring(resp.StatusCode)
		pcall(function() local d=HttpService:JSONDecode(resp.Body); if d.error and d.error.message then msg=msg..": "..d.error.message end end)
		return nil,msg
	end
	local ok2,data=pcall(HttpService.JSONDecode,HttpService,resp.Body)
	if not ok2 then return nil,"JSON_DECODE" end
	local reply=data.choices[1].message.content; ai_addToHistory(userId,"assistant",reply); return reply,nil
end

