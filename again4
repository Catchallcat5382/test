local function hookGunMod(taskKey)
    if TASK_ENUM and task_scheduler_module then
        local ok, task_scheduler = pcall(require, task_scheduler_module)
        if ok and task_scheduler then
            local ok2, upvalues = pcall(getupvalues, task_scheduler.add_task)
            if ok2 and upvalues then
                local taskList = upvalues[1] and upvalues[1][TASK_ENUM[taskKey]]
                if taskList then
                    for i, v in pairs(taskList) do
                        if type(v) == "function" then
                            pcall(hookfunction, v, function() return end)
                        end
                    end
                    return true
                end
            end
        end
    end

    local found = false
    pcall(function()
        for _, func in next, getgc(true) do
            if type(func) ~= "function" then continue end
            local ok, ups = pcall(getupvalues, func)
            if not ok or not ups then continue end
            for _, up in pairs(ups) do
                if type(up) == "table" then
                    for k, v in pairs(up) do
                        if k == taskKey and type(v) == "table" then
                            for _, fn in pairs(v) do
                                if type(fn) == "function" then
                                    pcall(hookfunction, fn, function() return end)
                                    found = true
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    if found then return true end

    pcall(function()
        for _, func in next, getgc(true) do
            if type(func) ~= "function" then continue end
            local info = debug and debug.getinfo and debug.getinfo(func)
            if info and info.name and info.name:lower():find(taskKey:lower()) then
                pcall(hookfunction, func, newcclosure(function() return end))
                found = true
            end
        end
    end)

    return found
end

