local function IsWeaponModel(obj)
    if not obj:IsA("Model") then return false, nil end
    if obj.Name == "soldier_model" then return false, nil end
    if obj.Name:find("friendly_marker") then return false, nil end
    local weaponPos, isWeapon = nil, false
    local n = obj.Name:lower()
    for _, p in ipairs(WeaponPatterns) do
        if n:find(p, 1, true) then isWeapon = true break end
    end
    if not isWeapon then
        for _, child in ipairs(obj:GetChildren()) do
            local cn = child.Name:lower()
            for _, p in ipairs(WeaponPatterns) do
                if cn:find(p, 1, true) then
                    isWeapon = true
                    if child:IsA("BasePart") then weaponPos = child.Position end
                    break
                end
            end
            if isWeapon then break end
        end
    end
    if isWeapon and not weaponPos then
        local part = obj:FindFirstChildWhichIsA("BasePart", true)
        if part then weaponPos = part.Position end
    end
    return isWeapon, weaponPos
end

local function GetWeaponsNearby(position, radius)
    local weapons = {}
    for _, obj in ipairs(Workspace:GetChildren()) do
        local isW, wPos = IsWeaponModel(obj)
        if isW and wPos and (wPos - position).Magnitude < radius then
            weapons[obj] = true
        end
    end
    return weapons
end

local function HasNewWeaponNearby(position, known, radius)
    for _, obj in ipairs(Workspace:GetChildren()) do
        local isW, wPos = IsWeaponModel(obj)
        if isW and wPos and (wPos - position).Magnitude < radius and not known[obj] then
            return true
        end
    end
    return false
end

local function IsModelDead(model)
    local root = model:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    
    local pos, now = root.Position, tick()
    
    if not DeathTracker[model] then
        DeathTracker[model] = {
            lastPos=pos,
            lastMoveTime=now,
            wasActive=false,
            isDead=false,
            frozenTime=0,
            knownWeapons=GetWeaponsNearby(pos,10),
            lastWeaponCheck=now,
            noMoveCount=0
        }
        return false
    end
    
    local d = DeathTracker[model]
    local delta = pos - d.lastPos
    local horizontalMove = Vector3.new(delta.X, 0, delta.Z).Magnitude
    local verticalMove = math.abs(delta.Y)
    
    -- More sensitive movement detection
    local isMoving = horizontalMove > 0.05 or verticalMove > 0.1
    
    if isMoving then
        d.lastMoveTime = now
        d.wasActive = true
        d.frozenTime = 0
        d.noMoveCount = 0
        d.knownWeapons = GetWeaponsNearby(pos, 10)
        d.lastWeaponCheck = now
        d.isDead = false
    else
        d.frozenTime = now - d.lastMoveTime
        d.noMoveCount = d.noMoveCount + 1
    end
    
    -- Check if dead: frozen for a bit AND (weapon appeared OR been frozen too long)
    if not d.isDead and d.wasActive and d.frozenTime > 0.15 then
        if now - d.lastWeaponCheck > 0.1 then
            d.lastWeaponCheck = now
            if HasNewWeaponNearby(pos, d.knownWeapons, 8) then
                d.isDead = true
            end
        end
        
        -- Fallback: if frozen for too long with no movement at all
        if d.noMoveCount > 30 and d.frozenTime > 2.0 then
            d.isDead = true
        end
    end
    
    d.lastPos = pos
    return d.isDead
end

local function CleanupDeathTracker()
    for model in pairs(DeathTracker) do
        if not model or not model.Parent then DeathTracker[model] = nil end
    end
end

