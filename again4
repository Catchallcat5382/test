    return Tracers.cache[model]
end

function Tracers.Hide(t)
    if not t then return end
    t.Line.Visible = false
    t.Label.Visible = false
end

function Tracers.Destroy(t)
    if not t then return end
    pcall(function() t.Line:Destroy() end)
    pcall(function() t.Label:Destroy() end)
end

function Tracers.Step(cam, screenSize)
    if State.Unloaded or not Config.ESP_Enabled or not Config.ESP_Tracer then
        for _, t in pairs(Tracers.cache) do Tracers.Hide(t) end
        return
    end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local origin = Vector2.new(screenSize.X / 2, screenSize.Y / 2)
    local valid = {}
    for model, posData in pairs(ESP.posCache) do
        if not model or not model.Parent then continue end
        if Config.ESP_TeamCheck and model:FindFirstChild("friendly_marker") then continue end
        if Config.ESP_DeadCheck and IsModelDead(model) then continue end
        if posData.dist > Config.ESP_MaxDist then continue end
        local targetRoot = model:FindFirstChild("HumanoidRootPart")
        if not targetRoot then continue end
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {myChar, model}
        rayParams.IgnoreWater = true
        local rayDirection = (targetRoot.Position - myRoot.Position)
        local rayResult = workspace:Raycast(myRoot.Position, rayDirection, rayParams)
        if rayResult then
            local hitParent = rayResult.Instance.Parent
            if hitParent ~= model and not model:IsAncestorOf(rayResult.Instance) then continue end
        end
        local screenPos, visible = cam:WorldToViewportPoint(posData.pos)
        if not visible or screenPos.Z <= 0 then continue end
        valid[model] = true
        local t = Tracers.GetOrCreate(model)
        local target = Vector2.new(screenPos.X, screenPos.Y)
        local delta = target - origin
        local length = delta.Magnitude
        local angle = math.deg(math.atan2(delta.Y, delta.X)) - 90
        t.Line.BackgroundColor3 = Config.ESP_Rainbow and GetRainbowColor() or Color3.fromRGB(255, 40, 40)
        t.Line.Position = UDim2.new(0, origin.X, 0, origin.Y)
        t.Line.Size = UDim2.new(0, 2, 0, length)
        t.Line.Rotation = angle
        t.Line.Visible = true
        local labelPos = origin + (delta * 0.3)
        t.Label.Text = math.floor(posData.dist).."m"
        t.Label.Position = UDim2.new(0, labelPos.X - 30, 0, labelPos.Y - 7)
        t.Label.TextColor3 = Color3.fromRGB(255, 180, 180)
        t.Label.Visible = true
    end
    for model, t in pairs(Tracers.cache) do
        if not valid[model] then
            if not model or not model.Parent then
                Tracers.Destroy(t)
                Tracers.cache[model] = nil
            else
                Tracers.Hide(t)
            end
        end
    end
end

