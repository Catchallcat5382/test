function ESP.Render(esp, model, posData, cam, screenSize)
    if not esp or not model then return end
    local root = model:FindFirstChild("HumanoidRootPart")
    if not root then ESP.Hide(esp) return end
    local dist = posData.dist
    if dist > Config.ESP_MaxDist then ESP.Hide(esp) return end
    local rs = cam:WorldToViewportPoint(posData.pos)
    if rs.Z <= 0 or rs.X < -100 or rs.X > screenSize.X+100 or rs.Y < -100 or rs.Y > screenSize.Y+100 then ESP.Hide(esp) return end
    local isDead = Config.ESP_DeadCheck and IsModelDead(model) or false
    local baseCol = isDead and Palette.Dead or (Config.ESP_Rainbow and GetRainbowColor() or GetEspColor())
    local baseSize = 1200 / math.max(rs.Z, 1)
    local bH = math.clamp(baseSize, 25, screenSize.Y * 0.8)
    local bW = math.clamp(bH * Tuning.BoxRatio, 15, screenSize.X * 0.5)
    local cx, cy = rs.X, rs.Y
    local bTop = cy - bH*0.55 local bBot = cy + bH*0.45
    local bLeft = cx - bW/2  local bRight = cx + bW/2
    esp.DeadX1.Visible = false esp.DeadX2.Visible = false
    if isDead then
        esp.Box.Visible = false
        for _, c in ipairs(esp.Corners) do c.Visible = false end
        local xs = math.min(bW, bH)*0.4
        esp.DeadX1.Position = UDim2.new(0,cx-xs,0,cy-2) esp.DeadX1.Size = UDim2.new(0,xs*2,0,4) esp.DeadX1.Visible = true
        esp.DeadX2.Position = UDim2.new(0,cx-xs,0,cy-2) esp.DeadX2.Size = UDim2.new(0,xs*2,0,4) esp.DeadX2.Visible = true
        esp.Name.Text = "DEAD" esp.Name.Position = UDim2.new(0,cx-100,0,cy-bH*0.3-14) esp.Name.TextColor3 = Palette.Dead esp.Name.Visible = true
        esp.Dist.Visible = false esp.Tracer.Visible = false
    else
        if Config.ESP_Box then
            if Config.ESP_BoxStyle == "Full" then
                for _, c in ipairs(esp.Corners) do c.Visible = false end
                esp.Box.Position = UDim2.new(0,bLeft,0,bTop) esp.Box.Size = UDim2.new(0,bW,0,bH)
                esp.BoxStroke.Color = baseCol esp.Box.Visible = true
            else
                esp.Box.Visible = false
                local cl = Tuning.CornerLen
                local co = esp.Corners
                co[1].Position=UDim2.new(0,bLeft,0,bTop)      co[1].Size=UDim2.new(0,cl,0,1.5)
                co[2].Position=UDim2.new(0,bLeft,0,bTop)      co[2].Size=UDim2.new(0,1.5,0,cl)
                co[3].Position=UDim2.new(0,bRight-cl,0,bTop)  co[3].Size=UDim2.new(0,cl,0,1.5)
                co[4].Position=UDim2.new(0,bRight-1.5,0,bTop) co[4].Size=UDim2.new(0,1.5,0,cl)
                co[5].Position=UDim2.new(0,bLeft,0,bBot-1.5)  co[5].Size=UDim2.new(0,cl,0,1.5)
                co[6].Position=UDim2.new(0,bLeft,0,bBot-cl)   co[6].Size=UDim2.new(0,1.5,0,cl)
                co[7].Position=UDim2.new(0,bRight-cl,0,bBot-1.5) co[7].Size=UDim2.new(0,cl,0,1.5)
                co[8].Position=UDim2.new(0,bRight-1.5,0,bBot-cl) co[8].Size=UDim2.new(0,1.5,0,cl)
                for _, c in ipairs(co) do c.BackgroundColor3 = baseCol c.Visible = true end
            end
        else
            esp.Box.Visible = false
            for _, c in ipairs(esp.Corners) do c.Visible = false end
        end
        if Config.ESP_Name then
            esp.Name.Text = "ENEMY"
            esp.Name.Position = UDim2.new(0,cx-100,0,bTop-17)
            esp.Name.TextColor3 = baseCol esp.Name.Visible = true
        else esp.Name.Visible = false end
        if Config.ESP_Distance then
            esp.Dist.Text = math.floor(dist).."m"
            esp.Dist.Position = UDim2.new(0,cx-100,0,bBot+4)
            esp.Dist.Visible = true
        else esp.Dist.Visible = false end
        esp.Tracer.Visible = false
    end
end

function ESP.CachePositions()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local myPos  = myRoot and myRoot.Position or Vector3.zero

    ESP.posCache = {}

    for _, model in pairs(workspace:GetDescendants()) do
        if model.Name == "soldier_model" and model.Parent then

            local cf, size = model:GetBoundingBox()

            local top = cf.Position + Vector3.new(0, size.Y/2, 0)
            local bottom = cf.Position - Vector3.new(0, size.Y/2, 0)

            ESP.posCache[model] = {
                top = top,
                bottom = bottom,
                cf = cf,
                size = size
            }

        end
    end
end

function ESP.Cleanup()
    local rm = {}
    for model, esp in pairs(ESP.cache) do
        if not model or not model.Parent or not model:FindFirstChild("HumanoidRootPart") then
            ESP.Hide(esp) ESP.Destroy(esp) rm[#rm+1] = model
        end
    end
    for _, m in ipairs(rm) do ESP.cache[m] = nil DeathTracker[m] = nil end
    CleanupDeathTracker()
end

function ESP.Step(cam, screenSize)
    if State.Unloaded or not Config.ESP_Enabled then
        for _, esp in pairs(ESP.cache) do ESP.Hide(esp) end return
    end

    local now = tick()
    if now - ESP.lastCleanup > Tuning.CleanupRate then ESP.lastCleanup = now ESP.Cleanup() end
    if now - ESP.lastPosUpdate > Tuning.CacheRate then ESP.lastPosUpdate = now ESP.CachePositions() end

    local valid = {}

    for model, posData in pairs(ESP.posCache) do
    if model and model.Parent then

        local isDead = Config.ESP_DeadCheck and not IsAlive(model)

        if isDead then
            if ESP.cache[model] then
                ESP.Hide(ESP.cache[model])
            end

        elseif Config.ESP_TeamCheck and model:FindFirstChild("friendly_marker") then
            if ESP.cache[model] then
                ESP.Hide(ESP.cache[model])
            end

        else
            valid[model] = true

			if Config.ESP_Highlight then
			if not highlightCache[model] then
				local highlight = Instance.new("Highlight")
				highlight.Adornee = model
				highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
				highlight.Parent = game.CoreGui
				highlightCache[model] = highlight
			end

			local highlight = highlightCache[model]

			if Config.Rainbow then
				local col = Color3.fromHSV(tick()%5/5,1,1)
				highlight.FillColor = col
				highlight.OutlineColor = col
			else
				highlight.FillColor = Palette.Enemy
				highlight.OutlineColor = Palette.Enemy
			end
		else
			if highlightCache[model] then
				highlightCache[model]:Destroy()
				highlightCache[model] = nil
			end
		end

            if not ESP.cache[model] then ESP.CreateDrawings(model) end
            ESP.Render(ESP.cache[model], model, posData, cam, screenSize)
        end

    end
end

    for model, esp in pairs(ESP.cache) do
        if not valid[model] then ESP.Hide(esp) end
    end
end

