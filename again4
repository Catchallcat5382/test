function Radar.GetOrCreateDot(idx)
    if Radar.DotPool[idx] then return Radar.DotPool[idx] end
    local dot = Instance.new("Frame")
    dot.BackgroundColor3 = Palette.Enemy
    dot.BorderSizePixel = 0
    dot.Size = UDim2.new(0, RADAR_DOT, 0, RADAR_DOT)
    dot.ZIndex = 13
    dot.Visible = false
    dot.Parent = Radar.RadarArea
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(0, 30, 0, 10)
    lbl.Position = UDim2.new(1, 2, 0, -2)
    lbl.Font = Enum.Font.RobotoMono
    lbl.TextSize = 7
    lbl.TextColor3 = Color3.fromRGB(255, 180, 180)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 14
    lbl.Parent = dot
    Radar.DotPool[idx] = {Dot=dot, Label=lbl}
    return Radar.DotPool[idx]
end

function Radar.Step(cam)
    if not Radar.Container then return end
    if State.Unloaded or not Config.RADAR_Enabled then
        Radar.Container.Visible = false
        return
    end
    Radar.Container.Visible = true
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local myPos = myRoot.Position
    local camCF = cam.CFrame
    local lookDir = camCF.LookVector
    local camYaw = math.atan2(lookDir.X, lookDir.Z)
    Radar.DirLine.Rotation = math.deg(-camYaw)
    local dotIndex = 0
    for model, posData in pairs(ESP.posCache) do
        if not model or not model.Parent then continue end
        if Config.ESP_TeamCheck and model:FindFirstChild("friendly_marker") then continue end
        if IsHumanoidDead(model) then continue end
        local dist = posData.dist
        if dist > RADAR_RANGE then continue end
        dotIndex = dotIndex + 1
        local entry = Radar.GetOrCreateDot(dotIndex)
        local offset = posData.pos - myPos
        local cosY = math.cos(camYaw)
        local sinY = math.sin(camYaw)
        local rx =  offset.X * cosY - offset.Z * sinY
        local ry = -offset.X * sinY - offset.Z * cosY
        local normX = math.clamp(rx / RADAR_RANGE, -0.95, 0.95)
        local normY = math.clamp(ry / RADAR_RANGE, -0.95, 0.95)
        local px = 0.5 + normX * 0.5
        local py = 0.5 + normY * 0.5
        entry.Dot.BackgroundColor3 = Palette.Enemy
        entry.Dot.Position = UDim2.new(px, -RADAR_DOT/2, py, -RADAR_DOT/2)
        entry.Dot.Visible = true
        entry.Label.Text = math.floor(dist).."m"
        entry.Label.Visible = dist < RADAR_RANGE * 0.9
    end
    for i = dotIndex + 1, #Radar.DotPool do
        if Radar.DotPool[i] then Radar.DotPool[i].Dot.Visible = false end
    end
end

