local AimAssist = {}
AimAssist.CurrentTarget = nil

local function IsStickyTargetValid(target, cam)
    if not target or not target.Parent then return false end
    local parentModel = target.Parent
    if parentModel and IsHumanoidDead(parentModel) then return false end
    local viewport = cam.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    local screenPos, visible = cam:WorldToViewportPoint(target.Position)
    if not visible or screenPos.Z <= 0 then return false end
    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
    if dist > Config.AIM_FOV * 1.5 then return false end
    return true
end

function AimAssist.GetTarget(cam)
    local bestPart = nil
    local bestDist = Config.AIM_FOV or 250
    local viewport = cam.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    for model, posData in pairs(ESP.posCache) do
        if model and model.Parent and IsEnemy(model) then
            if IsHumanoidDead(model) then continue end
            local targetPart =
                model:FindFirstChild(Config.AIM_TargetPart)
                or model:FindFirstChild("Head")
                or model:FindFirstChild("HumanoidRootPart")
            if targetPart then
                local vel = targetPart.AssemblyLinearVelocity or Vector3.zero
                local predicted = targetPart.Position + vel * Config.AIM_Prediction
                local screenPos, visible = cam:WorldToViewportPoint(predicted)
                if visible and screenPos.Z > 0 then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestPart = targetPart
                    end
                end
            end
        end
    end
    return bestPart
end

function AimAssist.GetLockedTarget(cam)
    if Config.AIM_Sticky and AimAssist.CurrentTarget then
        if IsStickyTargetValid(AimAssist.CurrentTarget, cam) then
            return AimAssist.CurrentTarget
        else
            AimAssist.CurrentTarget = nil
        end
    end
    local newTarget = AimAssist.GetTarget(cam)
    AimAssist.CurrentTarget = newTarget
    return newTarget
end

function AimAssist.Step(cam)
    local viewport = cam.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    if Config.AIM_ShowFOV then
        FOVCircle.Position = center
        FOVCircle.Radius = Config.AIM_FOV
        FOVCircle.Color = Config.FOV_Rainbow and GetRainbowColor() or (State.Aiming and Palette.FOV_Active or Palette.FOV_Circle)
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end
    if not Config.AIM_Enabled then
        LockCircle.Visible = false
        AimAssist.CurrentTarget = nil
        return
    end
    if not State.Aiming then
        LockCircle.Visible = false
        return
    end
    local target = AimAssist.GetLockedTarget(cam)
    if not target then
        LockCircle.Visible = false
        return
    end
    local vel = target.AssemblyLinearVelocity or Vector3.zero
    local predicted = target.Position + vel * Config.AIM_Prediction
    local screenPos, visible = cam:WorldToViewportPoint(predicted)
    if not visible or screenPos.Z <= 0 then
        LockCircle.Visible = false
        return
    end
    local delta = Vector2.new(screenPos.X - center.X, screenPos.Y - center.Y)
    local distance = delta.Magnitude
    local strength = Config.AIM_Strength or 2
    if distance < 40 then
        strength = strength * 1.8
    elseif distance < 90 then
        strength = strength * 1.3
    end
    local smooth = math.clamp(Config.AIM_Smooth, 0.01, 1)
    delta = delta * smooth * strength
    if math.abs(delta.X) < Config.AIM_Deadzone and math.abs(delta.Y) < Config.AIM_Deadzone then
        LockCircle.Position = Vector2.new(screenPos.X, screenPos.Y)
        LockCircle.Visible = true
        return
    end
    local maxMove = 35
    delta = Vector2.new(
        math.clamp(delta.X, -maxMove, maxMove),
        math.clamp(delta.Y, -maxMove, maxMove)
    )
    if mousemoverel then mousemoverel(delta.X, delta.Y) end
    LockCircle.Position = Vector2.new(screenPos.X, screenPos.Y)
    LockCircle.Visible = true
end

