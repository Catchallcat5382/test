local Noclip = {Initialized=false, Connection=nil}
function Noclip.DisableCollision(m)
    for _, p in pairs(m:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end
function Noclip.Init()
    if Noclip.Initialized then return end Noclip.Initialized = true
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj.Name:find("soldier") then Noclip.DisableCollision(obj) end
    end
    Noclip.Connection = Workspace.DescendantAdded:Connect(function(obj)
        if not Config.MISC_Noclip then return end
        task.wait(0.3)
        if obj.Name:find("soldier") then
            repeat task.wait() until obj:FindFirstChild("HumanoidRootPart")
            Noclip.DisableCollision(obj)
        end
    end)
end
function Noclip.Step()
    if Config.MISC_Noclip and not Noclip.Initialized then Noclip.Init() end
end

local OriginalRenderSettings = {
    QualityLevel = settings().Rendering.QualityLevel,
}
local PerformanceApplied = false

local function ApplyPerformance()
    if Config.MISC_Performance and not PerformanceApplied then
        PerformanceApplied = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        task.spawn(function()
            local descendants = Workspace:GetDescendants()
            local i = 1
            while i <= #descendants do
                for j = i, math.min(i + 49, #descendants) do
                    local obj = descendants[j]
                    if obj:IsA("ParticleEmitter") or obj:IsA("Smoke")
                    or obj:IsA("Fire") or obj:IsA("Sparkles") then
                        obj.Enabled = false
                    elseif obj:IsA("BasePart") then
                        obj.CastShadow = false
                    end
                end
                i = i + 50
                task.wait()
            end
        end)
    elseif not Config.MISC_Performance and PerformanceApplied then
        PerformanceApplied = false
        settings().Rendering.QualityLevel = OriginalRenderSettings.QualityLevel
    end
end

