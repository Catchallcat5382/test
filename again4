        tab.Indicator.Visible = sel
    end
end

function GUI.UpdateContent()
    for _, child in ipairs(GUI.ContentFrame:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") or child:IsA("ScrollingFrame") then child:Destroy() end
    end
    GUI.Items = {}
    local order = 0
    for _, mi in ipairs(MenuItems) do
        if mi.tab ~= Config.MENU_Tab then continue end
        order = order + 1
        local isLabel  = mi.type == "label"
        local isSlider = mi.type == "slider"
        local isGunMod = mi.type == "gunmod"
        local isNotes  = mi.type == "notes"
        local itemH = isLabel and 22 or isSlider and 42 or isNotes and 80 or 26

        local item = makeRound(GUI.ContentFrame, isLabel and Color3.fromRGB(10,10,14) or Palette.MenuPanel, 4)
        item.Name = mi.name
        item.Size = UDim2.new(1,0,0,itemH)
        item.LayoutOrder = order

        if isLabel then
            local sep = Instance.new("Frame")
            sep.BackgroundColor3 = Palette.MenuAccent sep.BackgroundTransparency = 0.6
            sep.BorderSizePixel = 0 sep.Position = UDim2.new(0,6,0.5,0)
            sep.Size = UDim2.new(0,3,0,10) sep.Parent = item
            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1 lbl.Position = UDim2.new(0,16,0,0)
            lbl.Size = UDim2.new(1,-16,1,0) lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 11 lbl.TextColor3 = Palette.MenuAccent
            lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Text = mi.name
            lbl.Parent = item

        elseif isGunMod then
            local applied = GunModsApplied[mi.key] or false
            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1 lbl.Position = UDim2.new(0,10,0,0)
            lbl.Size = UDim2.new(0.55,0,1,0) lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 12 lbl.TextColor3 = Palette.MenuText
            lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Text = mi.name
            lbl.Parent = item
            local applyBtn = makeRound(item, applied and Color3.fromRGB(30,60,30) or Color3.fromRGB(25,18,40), 4)
            applyBtn.Position = UDim2.new(1,-80,0.5,-10)
            applyBtn.Size = UDim2.new(0,72,0,20)
            local applyLbl = Instance.new("TextLabel")
            applyLbl.BackgroundTransparency = 1 applyLbl.Size = UDim2.new(1,0,1,0)
            applyLbl.Font = Enum.Font.GothamBold applyLbl.TextSize = 11
            applyLbl.TextXAlignment = Enum.TextXAlignment.Center
            applyLbl.TextColor3 = applied and Palette.MenuOn or Palette.MenuAccent
            applyLbl.Text = applied and "✓ ACTIVE" or "APPLY"
            applyLbl.Parent = applyBtn
            local hitbox = Instance.new("TextButton")
            hitbox.BackgroundTransparency = 1 hitbox.Size = UDim2.new(1,0,1,0) hitbox.Text = ""
            hitbox.Parent = item
            hitbox.MouseButton1Click:Connect(function()
                if GunModsApplied[mi.key] then return end
                local success = hookGunMod(mi.taskKey)
                if success then
                    GunModsApplied[mi.key] = true
                    applyBtn.BackgroundColor3 = Color3.fromRGB(30,60,30)
                    applyLbl.TextColor3 = Palette.MenuOn
                    applyLbl.Text = "✓ ACTIVE"
                else
                    applyLbl.Text = "FAILED"
                    applyLbl.TextColor3 = Color3.fromRGB(255,80,80)
                end
            end)

        else
            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1 lbl.Position = UDim2.new(0,10,0,0)
            lbl.Size = UDim2.new(0.55,0,0,24) lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 12 lbl.TextColor3 = Palette.MenuText
            lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Text = mi.name
            lbl.Parent = item

            if mi.type == "toggle" then
                local pill = makeRound(item, Config[mi.key] and Palette.MenuOn or Palette.MenuOff, 10)
                pill.Name = "Pill"
                pill.Position = UDim2.new(1,-42,0.5,-10)
                pill.Size = UDim2.new(0,34,0,18)
                local knob = makeRound(pill, Color3.new(1,1,1), 7)
                knob.Name = "Knob"
                knob.Size = UDim2.new(0,14,0,14)
                knob.Position = Config[mi.key] and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
                local hitbox = Instance.new("TextButton")
                hitbox.BackgroundTransparency = 1 hitbox.Size = UDim2.new(1,0,1,0) hitbox.Text = ""
                hitbox.Parent = item
                hitbox.MouseButton1Click:Connect(function()
                    Config[mi.key] = not Config[mi.key]
                    pill.BackgroundColor3 = Config[mi.key] and Palette.MenuOn or Palette.MenuOff
                    knob.Position = Config[mi.key] and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
                end)

            elseif mi.type == "slider" then
                local val = Config[mi.key]
                local function fmtV(v)
                    return mi.step < 1 and string.format("%.2f",v) or tostring(math.floor(v))
                end
                local valLbl = Instance.new("TextLabel")
                valLbl.BackgroundTransparency = 1 valLbl.Position = UDim2.new(1,-48,0,0)
                valLbl.Size = UDim2.new(0,42,0,22) valLbl.Font = Enum.Font.RobotoMono
                valLbl.TextSize = 11 valLbl.TextColor3 = Palette.MenuAccent
                valLbl.TextXAlignment = Enum.TextXAlignment.Right valLbl.Text = fmtV(val)
                valLbl.Parent = item
                local track = makeRound(item, Color3.fromRGB(25,25,34), 4)
                track.Name = "Track" track.Position = UDim2.new(0,10,0,26) track.Size = UDim2.new(1,-20,0,8)
                local pct = (val - mi.min) / (mi.max - mi.min)
                local fill = makeRound(track, Palette.MenuAccent, 4)
                fill.Name = "Fill" fill.Size = UDim2.new(pct,0,1,0)
                local thumb = makeRound(track, Color3.new(1,1,1), 5)
                thumb.Name = "Thumb" thumb.Size = UDim2.new(0,10,0,10)
                thumb.AnchorPoint = Vector2.new(0.5,0.5)
                thumb.Position = UDim2.new(pct,0,0.5,0)
                local dragging = false
                local function updateSlider(mx)
                    local tx = track.AbsolutePosition.X
                    local tw = track.AbsoluteSize.X
                    local p = math.clamp((mx - tx) / tw, 0, 1)
                    local v = mi.min + p * (mi.max - mi.min)
                    v = math.floor(v / mi.step + 0.5) * mi.step
                    Config[mi.key] = math.clamp(v, mi.min, mi.max)
                    local np = (Config[mi.key]-mi.min)/(mi.max-mi.min)
                    fill.Size = UDim2.new(np,0,1,0)
                    thumb.Position = UDim2.new(np,0,0.5,0)
                    valLbl.Text = fmtV(Config[mi.key])
                end
                track.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        updateSlider(UserInputService:GetMouseLocation().X)
                    end
                end)
                track.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                local conn = RunService.RenderStepped:Connect(function()
                    if dragging then updateSlider(UserInputService:GetMouseLocation().X) end
                end)
                Connections["sldr_"..mi.key] = conn

            elseif mi.type == "dropdown" then
                local idx = 1
                for i2, opt in ipairs(mi.options) do
                    if opt == Config[mi.key] then idx = i2 break end
                end
                local ddBox = makeRound(item, Color3.fromRGB(20,20,28), 4)
                ddBox.Position = UDim2.new(1,-100,0.5,-10) ddBox.Size = UDim2.new(0,92,0,20)
                local ddLbl = Instance.new("TextLabel")
                ddLbl.BackgroundTransparency = 1 ddLbl.Size = UDim2.new(1,-16,1,0)
                ddLbl.Position = UDim2.new(0,6,0,0) ddLbl.Font = Enum.Font.Gotham
                ddLbl.TextSize = 11 ddLbl.TextColor3 = Palette.MenuAccent
                ddLbl.TextXAlignment = Enum.TextXAlignment.Left ddLbl.Text = Config[mi.key]
                ddLbl.Parent = ddBox
                local arrow = Instance.new("TextLabel")
                arrow.BackgroundTransparency = 1 arrow.Position = UDim2.new(1,-16,0,0)
                arrow.Size = UDim2.new(0,14,1,0) arrow.Font = Enum.Font.GothamBold
                arrow.TextSize = 11 arrow.TextColor3 = Palette.MenuTextDim arrow.Text = "▾"
                arrow.Parent = ddBox
                local hitbox = Instance.new("TextButton")
                hitbox.BackgroundTransparency = 1 hitbox.Size = UDim2.new(1,0,1,0) hitbox.Text = ""
                hitbox.Parent = item
                hitbox.MouseButton1Click:Connect(function()
                    idx = idx % #mi.options + 1
                    Config[mi.key] = mi.options[idx]
                    ddLbl.Text = Config[mi.key]
                end)

            elseif isNotes then
                local scrollFrame = Instance.new("ScrollingFrame")
                scrollFrame.BackgroundTransparency = 1
                scrollFrame.Position = UDim2.new(0,10,0,5)
                scrollFrame.Size = UDim2.new(1,-20,1,-10)
                scrollFrame.CanvasSize = UDim2.new(0,0,0,0)
                scrollFrame.ScrollBarThickness = 3
                scrollFrame.ScrollBarImageColor3 = Palette.MenuAccent
                scrollFrame.BorderSizePixel = 0
                scrollFrame.Parent = item
                
                local text = Instance.new("TextLabel")
                text.BackgroundTransparency = 1
                text.Position = UDim2.new(0,0,0,0)
                text.Size = UDim2.new(1,-8,0,0)
                text.Font = Enum.Font.Gotham
                text.TextSize = 11
                text.TextColor3 = Palette.MenuTextDim
                text.TextXAlignment = Enum.TextXAlignment.Left
                text.TextYAlignment = Enum.TextYAlignment.Top
                text.TextWrapped = true
                text.Text = mi.text or "Notes"
                text.AutomaticSize = Enum.AutomaticSize.Y
                text.Parent = scrollFrame
                
                task.defer(function()
                    scrollFrame.CanvasSize = UDim2.new(0,0,0,text.AbsoluteSize.Y + 5)
                end)
            end
        end

        GUI.Items[#GUI.Items+1] = item
    end

    task.defer(function()
        local layout = GUI.ContentFrame:FindFirstChildWhichIsA("UIListLayout")
        if layout then
            GUI.ContentFrame.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+12)
        end
    end)
end

function GUI.Step()
    -- Title bar drag
    if GUI.Dragging then
        local m = UserInputService:GetMouseLocation()
        local np = m - GUI.DragOffset
        GUI.Frame.Position = UDim2.new(0, np.X, 0, np.Y)
    end
    -- Bottom handle drag
    if menuDragStep then menuDragStep() end
end

