-- ─── DRAG FRAME HELPER ──────────────────────────────────────────────────────
local function MakeDraggable(targetFrame)
    local dragging = false
    local dragOffset = Vector2.zero

    targetFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true

            local mouse = UserInputService:GetMouseLocation()
            dragOffset = mouse - Vector2.new(
                targetFrame.AbsolutePosition.X,
                targetFrame.AbsolutePosition.Y
            )
        end
    end)

    targetFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    RunService.RenderStepped:Connect(function()
        if dragging then
            local mouse = UserInputService:GetMouseLocation()
            local newPos = mouse - dragOffset

            targetFrame.Position = UDim2.new(
                0, newPos.X,
                0, newPos.Y
            )
        end
    end)
end

